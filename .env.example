# Required
DATABASE_URL=postgres://mesh:mesh@timescaledb:5432/mesher
VALKEY_URL=valkey://valkey:6379
SESSION_SECRET=change-me-to-a-random-64-char-string

# Tier: "oss" (default) or "saas"
MESHER_TIER=oss

# HTTP
HTTP_PORT=8080

# SMTP (required for password reset + invites)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Google OAuth (SaaS only)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
